.page-shell{box-sizing:border-box;min-height:100vh;padding:calc(28rpx + env(safe-area-inset-top)) 28rpx calc(54rpx + env(safe-area-inset-bottom))}.top-actions{display:flex;justify-content:space-between;margin-bottom:24rpx}.top-actions button{min-width:116rpx;margin:0;padding:12rpx 20rpx;border-radius:999rpx;background:#fffdf9;color:#69716b;font-size:25rpx;line-height:1.4}
.answer-card{padding:36rpx 32rpx;border:1rpx solid #eadcc8;border-radius:34rpx;background:linear-gradient(145deg,#fffdf8,#f4ebdd);box-shadow:0 20rpx 48rpx rgba(31,43,42,.1)}.eyebrow,.title,.code,.answer{display:block}.eyebrow{color:#b64c35;font-size:21rpx;font-weight:800;letter-spacing:3rpx}.title-row{display:flex;align-items:flex-start;justify-content:space-between;gap:20rpx;margin-top:20rpx}.title{font-size:42rpx;font-weight:800}.code{margin-top:6rpx;color:#8f948d;font-size:23rpx}.badge{flex:none;padding:8rpx 16rpx;border-radius:999rpx;background:#f6e8df;color:#b64c35;font-size:22rpx;font-weight:800}.answer{margin-top:28rpx;font-size:31rpx;font-weight:800;line-height:1.55}.score-row{display:flex;gap:14rpx;margin-top:26rpx}.score-row text{padding:8rpx 14rpx;border-radius:999rpx;background:rgba(255,255,255,.76);color:#69716b;font-size:22rpx;font-weight:700}
.metric-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx;margin-top:20rpx}.metric{padding:24rpx 22rpx;border-radius:24rpx;background:#fffdf9;box-shadow:0 12rpx 34rpx rgba(31,43,42,.06)}.metric text{display:block}.metric text:first-child{color:#8f948d;font-size:22rpx}.metric text:last-child{margin-top:8rpx;font-size:28rpx;font-weight:800;line-height:1.4}
.section-card,.risk{margin-top:20rpx;padding:28rpx;border-radius:28rpx;background:#fffdf9;box-shadow:0 12rpx 34rpx rgba(31,43,42,.06)}.section-title{display:block;margin-bottom:16rpx;font-size:29rpx;font-weight:800}.fact{display:flex;justify-content:space-between;gap:24rpx;padding:17rpx 0;border-top:1rpx solid #ece5d9;font-size:25rpx;line-height:1.5}.fact text:first-child{flex:none;color:#8f948d}.fact text:last-child{text-align:right}.risk{background:#f8eee5;color:#6f4437;font-size:25rpx;line-height:1.65}.deep-button{width:100%;min-height:92rpx;margin-top:24rpx;border-radius:999rpx;background:#1f2b2a;color:#fff;font-size:28rpx;font-weight:800}.source{display:block;margin-top:24rpx;color:#a19d93;font-size:21rpx;text-align:center}.empty{display:flex;min-height:440rpx;flex-direction:column;align-items:center;justify-content:center;gap:12rpx;border-radius:30rpx;background:#fffdf9;color:#8f948d;font-size:26rpx}.empty text:first-child{color:#1f2b2a;font-size:34rpx;font-weight:800}
