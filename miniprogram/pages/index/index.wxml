<view class="page-shell">
  <view class="brand-row">
    <text class="brand">望潮</text>
    <text class="brand-en">Aurum</text>
  </view>
  <view class="entry-list">
    <button
      wx:for="{{entries}}"
      wx:key="id"
      class="entry-card {{item.tone}}"
      data-target="{{item.id}}"
      bindtap="openEntry"
      hover-class="entry-card-active"
    >
      <text class="kicker">{{item.kicker}}</text>
      <view class="entry-title-row">
        <text class="entry-title">{{item.title}}</text>
        <text class="arrow">›</text>
      </view>
      <text class="question">{{item.question}}</text>
    </button>
  </view>
  <text class="disclaimer">仅用于信息整理和投资研究辅助，不构成投资建议或买卖指令。</text>
</view>
