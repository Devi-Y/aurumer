.page-shell {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 42rpx 28rpx calc(48rpx + env(safe-area-inset-bottom));
}

.brand-row {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  padding: 10rpx 6rpx 30rpx;
}

.brand {
  font-family: serif;
  font-size: 60rpx;
  font-weight: 700;
}

.brand-en {
  color: #69716b;
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.entry-card {
  box-sizing: border-box;
  width: 100%;
  min-height: 250rpx;
  margin: 0;
  padding: 34rpx 34rpx 30rpx;
  border-radius: 36rpx;
  color: #fffaf2;
  text-align: left;
  box-shadow: 0 20rpx 50rpx rgba(31, 43, 42, 0.12);
}

.entry-card.hk { background: linear-gradient(135deg, #9e4426, #c86a45); }
.entry-card.us { background: linear-gradient(135deg, #1e3a31, #356450); }
.entry-card.a { background: linear-gradient(135deg, #243c43, #436b72); }
.entry-card-active { transform: scale(0.985); opacity: 0.94; }

.kicker {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  opacity: 0.76;
}

.entry-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.entry-title {
  font-size: 48rpx;
  font-weight: 800;
}

.arrow {
  font-size: 54rpx;
}

.question {
  display: block;
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 28rpx;
  line-height: 1.65;
}

.disclaimer {
  display: block;
  padding: 38rpx 14rpx 0;
  color: #8f948d;
  font-size: 22rpx;
  line-height: 1.7;
  text-align: center;
}
