.page-shell{box-sizing:border-box;min-height:100vh;padding:calc(28rpx + env(safe-area-inset-top)) 28rpx calc(54rpx + env(safe-area-inset-bottom))}.top-actions{display:flex;justify-content:space-between;margin-bottom:24rpx}.top-actions button{min-width:116rpx;margin:0;padding:12rpx 20rpx;border-radius:999rpx;background:#fffdf9;color:#69716b;font-size:25rpx;line-height:1.4}
.page-head{padding:24rpx 8rpx 30rpx}.eyebrow,.title,.lead{display:block}.eyebrow{color:#b64c35;font-size:21rpx;font-weight:800;letter-spacing:3rpx}.title{margin-top:14rpx;font-size:48rpx;font-weight:800}.lead{margin-top:12rpx;color:#69716b;font-size:27rpx;line-height:1.6}
.item-list{display:flex;flex-direction:column;gap:20rpx}.item-card{width:100%;margin:0;padding:30rpx;border-radius:30rpx;background:#fffdf9;color:#1f2b2a;text-align:left;box-shadow:0 16rpx 42rpx rgba(31,43,42,.08)}.card-active{transform:scale(.985);opacity:.94}.item-top{display:flex;align-items:flex-start;justify-content:space-between;gap:18rpx}.item-name{font-size:33rpx;font-weight:800}.item-code{margin-left:12rpx;color:#8f948d;font-size:23rpx}.badge{flex:none;padding:8rpx 16rpx;border-radius:999rpx;background:#f6e8df;color:#b64c35;font-size:22rpx;font-weight:800}.answer{display:block;margin-top:24rpx;font-size:29rpx;font-weight:700;line-height:1.6}.item-foot{display:flex;justify-content:space-between;gap:18rpx;margin-top:24rpx;padding-top:20rpx;border-top:1rpx solid #ece5d9;color:#69716b;font-size:23rpx}.source{display:block;margin-top:30rpx;color:#a19d93;font-size:21rpx;text-align:center}.empty{padding:70rpx 30rpx;border-radius:30rpx;background:#fffdf9;color:#8f948d;text-align:center}.empty-title{display:block;margin-bottom:12rpx;color:#1f2b2a;font-size:31rpx;font-weight:800}
