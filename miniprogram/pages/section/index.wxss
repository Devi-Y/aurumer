.page-shell{box-sizing:border-box;min-height:100vh;padding:calc(28rpx + env(safe-area-inset-top)) 28rpx calc(54rpx + env(safe-area-inset-bottom))}
.top-actions{display:flex;justify-content:space-between;margin-bottom:24rpx}.top-actions button{min-width:116rpx;margin:0;padding:12rpx 20rpx;border-radius:999rpx;background:#fffdf9;color:#69716b;font-size:25rpx;line-height:1.4}
.hero{padding:38rpx 34rpx;border-radius:34rpx;color:#fff;box-shadow:0 22rpx 52rpx rgba(31,43,42,.12)}.hero.hk{background:linear-gradient(135deg,#9e4426,#c86a45)}.hero.us{background:linear-gradient(135deg,#1e3a31,#356450)}.hero.a{background:linear-gradient(135deg,#243c43,#436b72)}
.eyebrow,.title,.lead{display:block}.eyebrow{font-size:21rpx;font-weight:700;letter-spacing:3rpx;opacity:.72}.title{margin-top:16rpx;font-size:48rpx;font-weight:800}.lead{margin-top:14rpx;font-size:28rpx;line-height:1.6;opacity:.86}
.group-list{display:flex;flex-direction:column;gap:20rpx;margin-top:28rpx}.group-card{display:flex;align-items:center;justify-content:space-between;width:100%;min-height:168rpx;margin:0;padding:28rpx 30rpx;border-radius:30rpx;background:#fffdf9;color:#1f2b2a;text-align:left;box-shadow:0 16rpx 42rpx rgba(31,43,42,.08)}.card-active{transform:scale(.985);opacity:.94}.group-copy{flex:1;min-width:0}.group-title,.group-one{display:block}.group-title{font-size:34rpx;font-weight:800}.group-one{margin-top:10rpx;color:#69716b;font-size:26rpx;line-height:1.5}.group-meta{display:flex;align-items:center;gap:16rpx;margin-left:20rpx;color:#b64c35;font-size:30rpx;font-weight:800}.arrow{font-size:44rpx}
.source,.disclaimer{display:block;text-align:center}.source{margin-top:30rpx;color:#a19d93;font-size:21rpx}.disclaimer{margin-top:14rpx;color:#8f948d;font-size:22rpx;line-height:1.6}
